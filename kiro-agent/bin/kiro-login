#!/usr/bin/env bash
#
# kiro-login — Authenticate with the kiro-agent API and save your token.
# Starts a local callback server, opens the browser for Google OAuth,
# and captures the token automatically (like gcloud auth login).
#
# Usage:  ~/.claude/skills/kiro-agent/bin/kiro-login

set -euo pipefail

TOKEN_FILE="$HOME/.claude/skills/kiro-agent/.kiro-token"
API_BASE="https://app-service-lmqrue7ola-el.a.run.app"

echo ""
echo "kiro-agent login"
echo "================"
echo ""

# Start a one-shot local HTTP server on a random port to capture the token
# Node.js is required (already a project dependency)
if ! command -v node >/dev/null 2>&1; then
  echo "Error: Node.js is required but not found."
  exit 1
fi

# Find a free port and start the callback server
TOKEN=$(node -e '
const http = require("http");
const url = require("url");

const server = http.createServer((req, res) => {
  const parsed = url.parse(req.url, true);
  if (parsed.pathname === "/callback" && parsed.query.token) {
    res.writeHead(200, { "Content-Type": "text/html" });
    res.end("<html><body style=\"font-family:system-ui;text-align:center;padding:60px\">" +
      "<h1>Authenticated!</h1>" +
      "<p>You can close this tab and return to your terminal.</p>" +
      "</body></html>");
    process.stdout.write(parsed.query.token);
    setTimeout(() => server.close(() => process.exit(0)), 200);
  } else {
    res.writeHead(404);
    res.end("Not found");
  }
});

server.listen(0, "127.0.0.1", () => {
  const port = server.address().port;
  process.stderr.write("PORT:" + port + "\n");
});

// Timeout after 120 seconds
setTimeout(() => {
  process.stderr.write("Timed out waiting for authentication.\n");
  process.exit(1);
}, 120000);
' 2> >(
  # Read stderr to get the port, then open the browser
  while IFS= read -r line; do
    if [[ "$line" == PORT:* ]]; then
      PORT="${line#PORT:}"
      AUTH_URL="$API_BASE/auth/google?cli_port=$PORT"
      echo "Opening browser for Google sign-in..." >&2
      echo "" >&2
      if command -v open >/dev/null 2>&1; then
        open "$AUTH_URL"
      elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$AUTH_URL"
      else
        echo "Open this URL in your browser:" >&2
        echo "  $AUTH_URL" >&2
      fi
      echo "Waiting for authentication..." >&2
    else
      echo "$line" >&2
    fi
  done
))

if [ -z "${TOKEN:-}" ]; then
  echo ""
  echo "Login failed — no token received."
  exit 1
fi

mkdir -p "$(dirname "$TOKEN_FILE")"
echo "$TOKEN" > "$TOKEN_FILE"
chmod 600 "$TOKEN_FILE"

echo ""
echo "Verifying token..."
RESPONSE=$(curl -sf -H "Authorization: Bearer $TOKEN" "$API_BASE/hello" 2>&1 || echo "FAILED")

if echo "$RESPONSE" | grep -q "Hello, Kiro"; then
  EMAIL=$(echo "$RESPONSE" | grep -o '"email":"[^"]*"' | cut -d'"' -f4)
  echo ""
  echo "Authenticated as: $EMAIL"
  echo "Token saved to:   $TOKEN_FILE"
else
  echo "Verification failed. Response: $RESPONSE"
  rm -f "$TOKEN_FILE"
  exit 1
fi
